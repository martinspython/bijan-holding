# ──────────────────────────────────────────────
# Bijan Holding — Environment Variables
# ──────────────────────────────────────────────
# Copy to .env and fill in your values.
# Vercely: set these in Project Settings → Environment Variables

# ── General ───────────────────────────────────
BIJAN_ENV=development
BIJAN_APP_VERSION=1.0.0

# ── Control Panel (Fleet Management) ──────────
# Vercel Project: fleet (fleet.bijan.ir)
VITE_APP_TITLE=بیژن هولدینگ - سامانه مدیریت یکپارچه
VITE_APP_BASE_URL=/api
VITE_MAPLIBRE_STYLE=https://tile.openstreetmap.org/{z}/{x}/{y}.png

# ── Driver App (PWA) ─────────────────────────
# Vercel Project: driver-app (driver.bijan.ir)
VITE_APP_TITLE_DRIVER=بیژن هولدینگ - سامانه رانندگان
VITE_DRIVER_API_URL=/api/driver

# ── Commercial Intelligence Platform ──────────
# Vercel Project: commercial (commercial.bijan.ir)
VITE_APP_TITLE_COMMERCIAL=دفتر بازرگانی بیژن - سکوی هوشمند تدارکات
VITE_COMMERCIAL_API_URL=/api/commercial

# ── Monitoring & Analytics ────────────────────
# Vercel Analytics is auto-instrumented.
# Speed Insights: https://vercel.com/speed-insights
# Web Vitals: https://vercel.com/docs/analytics

# ── Auth (Mock — replace with real IdP) ──────
# For production, integrate Keycloak, Auth0, or Azure AD.
VITE_AUTH_MOCK=true
VITE_AUTH_TOKEN_KEY=bijan-token

# ── Feature Flags ─────────────────────────────
VITE_FEATURE_MAP=true
VITE_FEATURE_AI_NEGOTIATION=true
VITE_FEATURE_SUPPLY_CHAIN_TWIN=true

# ── Performance Budgets (Lighthouse) ──────────
# These are used by CI to assert performance.
PERF_LCP_TARGET=2500
PERF_FID_TARGET=100
PERF_CLS_TARGET=0.1
